--== Services & locals ==--
local HttpService     = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players         = game:GetService("Players")
local RunService      = game:GetService("RunService")
local LocalPlayer     = Players.LocalPlayer

--== HTTP wrapper รองรับหลาย executor ==--
local function httpGet(url)
    local ok, body = pcall(function()
        if syn and syn.request then
            return syn.request({Url = url, Method = "GET"}).Body
        elseif http_request then
            return http_request({Url = url, Method = "GET"}).Body
        elseif (request) then
            return request({Url = url, Method = "GET"}).Body
        elseif http and http.request then
            return http.request({Url = url, Method = "GET"}).Body
        else
            return game:HttpGet(url)
        end
    end)
    if ok then return body end
    warn("[httpGet] failed:", body)
    return nil
end

--== Utils ==--
local function getHRP(character)
    if not character then return nil end
    local ok, hrp = pcall(function()
        return character:FindFirstChild("HumanoidRootPart")
            or character:WaitForChild("HumanoidRootPart", 3)
    end)
    return ok and hrp or nil
end

local function getLocalHRP()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return getHRP(char)
end

--== ดึงรายชื่อ server ว่าง (รองรับหลายหน้า) ==--
local function fetchServers(placeId, maxPages)
    maxPages = maxPages or 5
    local servers = {}
    local seen = {}

    local base = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100")
        :format(placeId)
    local cursor

    for page = 1, maxPages do
        -- ✅ FIX: encode cursor
        local url = cursor and (base .. "&cursor=" .. HttpService:UrlEncode(cursor)) or base
        local body = httpGet(url)
        if not body then break end

        local ok, res = pcall(HttpService.JSONDecode, HttpService, body)
        if not ok or type(res) ~= "table" or type(res.data) ~= "table" then
            warn("[fetchServers] decode fail at page", page)
            break
        end

        for _, v in ipairs(res.data) do
            if type(v) == "table" then
                local id         = v.id
                local playing    = tonumber(v.playing) or 0
                local maxPlayers = tonumber(v.maxPlayers) or 0
                -- ✅ FIX: เผื่อ slot อย่างน้อย 2 ที่ ลด race condition
                if id and id ~= game.JobId
                   and playing > 0
                   and playing < (maxPlayers - 1)
                   and not seen[id] then
                    seen[id] = true
                    table.insert(servers, id)
                end
            end
        end

        cursor = res.nextPageCursor
        if not cursor or cursor == "" then break end
        task.wait(0.15)
    end

    return servers
end

--== Teleport (retry + fallback + log) ==--
local RNG = Random.new(tick() * 1e6)
local _hopping = false

local function server_hop()
    if _hopping then return end
    _hopping = true

    print("[server_hop] เริ่ม hop...")
    local list = fetchServers(game.PlaceId, 8)
    print(("[server_hop] พบ %d servers"):format(#list))

    if #list == 0 then
        warn("[server_hop] ไม่เจอ server → fallback random")
        pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
        task.wait(5)
        _hopping = false
        return
    end

    -- ✅ FIX: shuffle step ต้องเป็น -1
    for i = #list, 2, -1 do
        local j = RNG:NextInteger(1, i)
        list[i], list[j] = list[j], list[i]
    end

    local attempts = math.min(8, #list)
    for n = 1, attempts do
        local target = list[n]
        print(("[server_hop] ลองครั้งที่ %d/%d → %s"):format(n, attempts, tostring(target)))

        local ok, err = pcall(function()
            TeleportService:TeleportToPlaceInstance(game.PlaceId, target, LocalPlayer)
        end)

        if ok then
            -- ✅ FIX: รอให้ teleport เกิดจริง ไม่งั้น loop ข้างนอกอาจ retrigger
            task.wait(5)
            _hopping = false
            return
        else
            warn("[server_hop] fail:", err)
        end
        task.wait(0.8 + n * 0.3)
    end

    -- สุดท้ายยังไม่ได้
    pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
    task.wait(5)
    _hopping = false
end

-- retry อัตโนมัติเมื่อ teleport init ล้มเหลว
TeleportService.TeleportInitFailed:Connect(function(player, result, msg)
    if player == LocalPlayer then
        warn("[TeleportInitFailed]", result, msg)
        _hopping = false
        task.delay(2, server_hop)
    end
end)

--== หาเป้าหมายที่ใกล้ที่สุดในรัศมี ==--
local NEAR_RADIUS  = 150
local STAY_SECONDS = 10

local function get_nearest()
    local myHRP = getLocalHRP()
    if not myHRP then return nil, math.huge end

    local nearest, bestDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = getHRP(plr.Character)
            if hrp then
                local d = (myHRP.Position - hrp.Position).Magnitude
                if d < bestDist then
                    bestDist = d
                    nearest = plr
                end
            end
        end
    end
    return nearest, bestDist
end

local function check_nearby_player()
    if _hopping then return end
    local target, dist = get_nearest()
    if not target or dist > NEAR_RADIUS then return end

    local start = tick()
    while tick() - start < STAY_SECONDS do
        task.wait(1)
        local current, d = get_nearest()
        if current ~= target or not current or d > NEAR_RADIUS then
            return
        end
    end

    server_hop()
end

--== loop หลัก ==--
task.spawn(function()
    while task.wait(0.5) do
        xpcall(check_nearby_player, function(err)
            warn("[check_nearby_player]", err)
        end)
    end
end)

task.spawn(function()
    local _ = getLocalHRP()
end)

