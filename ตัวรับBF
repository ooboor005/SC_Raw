function getDistance(Endpoint: CFrame | Vector3 | BasePart | Part)
	if typeof(Endpoint) == "Vector3" then
		return (Endpoint - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
	end
	if typeof(Endpoint) == "Instance" and (Endpoint:IsA("BasePart") or Endpoint:IsA("Part")) then
		return (Endpoint.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
	end
	return (Endpoint.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
end

function Tween(Position: CFrame | Vector3 | Part | BasePart)
	local Endpoint = Position
	local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	if not Character then
		return
	end
	if not Humanoid then
		return
	end
	if not Character:FindFirstChild("CharacterReady") then
		return
	end
	if typeof(Endpoint) == "Instance" and (Endpoint:IsA("BasePart") or Endpoint:IsA("Part")) then
		Endpoint = Endpoint.CFrame
	elseif typeof(Endpoint) == "Vector3" then
		Endpoint = CFrame.new(Endpoint)
	end

	local Distance = getDistance(Endpoint)

	if Distance then
		if Character.HumanoidRootPart.CFrame.Y ~= Endpoint.Y then
			Character.HumanoidRootPart.CFrame =
				CFrame.new(Character.HumanoidRootPart.CFrame.X, Endpoint.Y, Character.HumanoidRootPart.CFrame.Z)
		end
		local TweenTime = Distance / 325

		local TweenInfoz = TweenService:Create(
			Character.HumanoidRootPart,
			TweenInfo.new(TweenTime, Enum.EasingStyle.Linear),
			{ CFrame = Endpoint }
		)

		TweenInfoz:Play()
        
        return TweenInfoz
	end
	return nil
end

