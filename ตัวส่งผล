local Map = workspace:WaitForChild("Map")
local Turtle = Map:WaitForChild("Turtle")
local TradeTable = Turtle:WaitForChild("TradeTable")

function getEmptyChair()
    for i, v in pairs(TradeTable:GetChildren()) do
        if (v.Name == "P1" or v.Name == "P2") and not v:FindFirstChildOfClass("Weld") then
            return v
        end
    end
    return nil
end

