    EmptyChair = getEmptyChair()
    if EmptyChair then
		Character.HumanoidRootPart.CFrame = CFrame.new(EmptyChair.Position)
	end
until Humanoid and Humanoid.Sit

-- ส่วนการจัดการ Inventory และการเทรด
local TradeFunction = Remotes:WaitForChild("TradeFunction")
local TradeEvent = Remotes:WaitForChild("TradeEvent")

-- ลบ game:Shutdown() และแก้ไข logic การรับ
TradeEvent.OnClientEvent:Connect(function(action, args)
	if action == "update_state" then
		local playerNumber = args["Player1"].Name == LocalPlayer.Name and 1 or args["Player2"].Name == LocalPlayer.Name and 2 or nil
		if not playerNumber then return end
		
		local FruitValueSelf, FruitValueOther = 0, 0
		for i,v in pairs(args.Offer[playerNumber]) do FruitValueSelf += v.Price end
		for i,v in pairs(args.Offer[playerNumber == 1 and 2 or 1]) do FruitValueOther += v.Price end
		
		-- ตรวจสอบมูลค่า 60% ตามกฎของเกม
		local canTrade = FruitValueSelf == 0 or (FruitValueOther / FruitValueSelf) * 100 >= 60
		if not args.Ready[playerNumber] and canTrade and FruitValueSelf > 0 then
			TradeFunction:InvokeServer("accept")
		end
	end
end)

-- ค้นหาผลไม้จาก Inventory ตามลำดับใน FruitTrade
local Inventory = CommF:InvokeServer("getInventory")
local FruitToInvite = nil

for _, targetName in ipairs(FruitTrade) do
    for _, item in pairs(Inventory) do
        if item.Name == targetName and item.Type == "Blox Fruit" then
            FruitToInvite = item.Name
            break
        end
    end
    if FruitToInvite then break end
end

