-- [Function Tween และ GetDistance เหมือนเดิม...]
function getDistance(Endpoint)
	local part = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not part then return 999999 end
	local pos = (typeof(Endpoint) == "Vector3" and Endpoint) or (Endpoint.Position)
	return (pos - part.Position).Magnitude
end

function Tween(Position)
	local Character = LocalPlayer.Character
	if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
	local Endpoint = (typeof(Position) == "Instance" and Position.CFrame) or (typeof(Position) == "Vector3" and CFrame.new(Position)) or Position
	local Distance = getDistance(Endpoint)
	if Distance then
		local TweenTime = Distance / 325
		local t = TweenService:Create(Character.HumanoidRootPart, TweenInfo.new(TweenTime, Enum.EasingStyle.Linear), {CFrame = Endpoint})
		t:Play()
		return t
	end
end

