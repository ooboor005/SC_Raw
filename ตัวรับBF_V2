	if LocalPlayer.PlayerGui:FindFirstChild("TradeLogGui") then
		LocalPlayer.PlayerGui.TradeLogGui:Destroy()
	end

	LogGui = Instance.new("ScreenGui")
	LogGui.Name = "TradeLogGui"
	LogGui.ResetOnSpawn = false
	LogGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	LogGui.Parent = LocalPlayer.PlayerGui

	-- ปุ่มเปิด/ปิด (ลอยมุมขวาบน)
	local ToggleBtn = Instance.new("TextButton")
	ToggleBtn.Name = "ToggleBtn"
	ToggleBtn.Size = UDim2.new(0, 90, 0, 30)
