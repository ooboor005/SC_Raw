-- สีต่างๆ
local CL_INFO  = Color3.fromRGB(180, 200, 230)
local CL_OK    = Color3.fromRGB(120, 220, 130)
local CL_WARN  = Color3.fromRGB(245, 200, 90)
local CL_ERR   = Color3.fromRGB(245, 100, 100)
local CL_DIM   = Color3.fromRGB(140, 140, 160)
local CL_HEAD  = Color3.fromRGB(120, 200, 255)

logMsg("[Trade] UI Console ready", CL_OK)

-- ========================================
-- Trade event handler with full diagnostics
-- ========================================
local TradeBusy = false

TradeEvent.OnClientEvent:Connect(function(action, args)
	if action == "update_state" then
		if TradeBusy then
			logMsg("[Trade] event received but busy - skipping", CL_DIM)
			return
		end
		TradeBusy = true

		logMsg("========== update_state ==========", CL_HEAD)

		local playerNumber = args["Player1"].Name == LocalPlayer.Name and 1 or args["Player2"].Name == LocalPlayer.Name and 2 or nil
		if not playerNumber then
			logMsg("[Trade] X Cannot determine playerNumber - exit", CL_ERR)
			TradeBusy = false
			return
		end
		logMsg("[Trade] We are Player " .. playerNumber, CL_INFO)

		local FruitValueSelf = 0
		local FruitValueOther = 0
		for i,v in pairs(args.Offer[playerNumber]) do 
			FruitValueSelf += v.Price 
		end
		for i,v in pairs(args.Offer[playerNumber == 1 and 2 or 1]) do 
			FruitValueOther += v.Price 
		end

		logMsg(("[Trade] Value Self=%d / Other=%d"):format(FruitValueSelf, FruitValueOther), CL_INFO)
		logMsg(("[Trade] Ready: Self=%s / Other=%s"):format(
			tostring(args.Ready[playerNumber]),
			tostring(args.Ready[playerNumber == 1 and 2 or 1])
		), CL_INFO)

		-- ของที่เราใส่
		local alreadyOffered = {}
		local selfOfferList = {}
		for i, v in pairs(args.Offer[playerNumber]) do
			alreadyOffered[v.Name] = true
			table.insert(selfOfferList, v.Name.." ("..tostring(v.Price)..")")
		end
		if #selfOfferList > 0 then
			logMsg("[Trade] Our offer: " .. table.concat(selfOfferList, ", "), CL_INFO)
		else
			logMsg("[Trade] We have not offered anything yet", CL_DIM)
		end

		-- ของที่อีกฝ่ายใส่
		local otherOfferList = {}
		for i, v in pairs(args.Offer[playerNumber == 1 and 2 or 1]) do
			table.insert(otherOfferList, v.Name.." ("..tostring(v.Price)..")")
		end
		if #otherOfferList > 0 then
			logMsg("[Trade] Their offer: " .. table.concat(otherOfferList, ", "), CL_INFO)
		else
			logMsg("[Trade] They have not offered anything yet", CL_DIM)
		end

		if FruitValueSelf > 0 and FruitValueOther > 0 then
			local ratio = (FruitValueOther / FruitValueSelf) * 100
			logMsg(("[Trade] Current ratio Other/Self = %.1f%% (need >=60%%)"):format(ratio), CL_INFO)
		end

		local addedValue = 0
		local conditionA = (FruitValueSelf == 0)
		local conditionB = not args.Ready[playerNumber] and FruitValueOther > 0 and FruitValueSelf > 0 and (FruitValueOther / FruitValueSelf) * 100 >= 60
		local shouldAddItems = conditionA or not conditionB

		logMsg(("[Trade] Add items? Self==0?=%s, ReadyToAccept?=%s -> %s"):format(
			tostring(conditionA), tostring(conditionB), tostring(shouldAddItems)
		), CL_INFO)

		if shouldAddItems then 
			logMsg("[Trade] -> Starting fruit selection", CL_HEAD)
			logMsg("[Trade]   refreshing inventory from server...", CL_DIM)
			refreshFruitMapping()

			local mapCount = 0
			local mapList = {}
			for k, v in pairs(FruitMapping) do
				mapCount += 1
				table.insert(mapList, k.."="..tostring(v))
			end
			logMsg(("[Trade]   Inventory has %d Blox Fruits"):format(mapCount), CL_INFO)
			if mapCount > 0 then
				logMsg("[Trade]   List: " .. table.concat(mapList, ", "), CL_DIM)
			end

			-- ลบของที่ใส่ไปแล้ว
			local removedCount = 0
			for name, _ in pairs(alreadyOffered) do
				if FruitMapping[name] ~= nil then
					FruitMapping[name] = nil
					removedCount += 1
				end
			end
			if removedCount > 0 then
				logMsg(("[Trade]   Removed %d already-offered items"):format(removedCount), CL_DIM)
			end

			local remaining = 0
			for _ in pairs(FruitMapping) do remaining += 1 end
			logMsg(("[Trade]   %d remaining, threshold=%d (60%% of %d)"):format(
				remaining, FruitValueOther * 0.6, FruitValueOther
			), CL_INFO)

			if remaining == 0 then
				logMsg("[Trade] ! No more items to add", CL_WARN)
			else
				-- ✅ DEBUG: print sorted entries ก่อนเรียก getIndices
				local sortedDebug = {}
				for k, v in pairs(FruitMapping) do
					table.insert(sortedDebug, {name = k, val = v})
				end
				table.sort(sortedDebug, function(a, b) return a.val > b.val end)
				logMsg("[Trade]   Sorted by value (high->low):", CL_DIM)
				for i = 1, math.min(8, #sortedDebug) do
					logMsg(("[Trade]     #%d %s = %d"):format(i, sortedDebug[i].name, sortedDebug[i].val), CL_DIM)
				end

				-- คำนวณว่าถ้าใส่ 4 ตัวแรกจะได้เท่าไหร่
				local sumTop4 = 0
				for i = 1, math.min(4, #sortedDebug) do
					sumTop4 += sortedDebug[i].val
				end
				logMsg(("[Trade]   Top 4 sum=%d, need>%d"):format(sumTop4, FruitValueOther * 0.6), CL_INFO)

				local fruitIndices = getIndices(FruitMapping, FruitValueOther)
				logMsg(("[Trade]   getIndices returned %d items"):format(#fruitIndices), CL_INFO)

				if #fruitIndices == 0 then
					logMsg("[Trade] ! getIndices returned nothing - top 4 not enough", CL_WARN)
					logMsg("[Trade]   Try lowering threshold or increasing pick count", CL_DIM)
				end

				for i,v in pairs(fruitIndices) do 
					local val = FruitMapping[v] or 0
					logMsg(("[Trade]   -> addItem: %s (value %d)"):format(v, val), CL_INFO)

					local ok, err = pcall(function()
						TradeFunction:InvokeServer("addItem", v)
					end)
					if ok then
						logMsg("[Trade]   OK sent", CL_OK)
						addedValue += val
					else
						logMsg("[Trade]   X send failed: " .. tostring(err), CL_ERR)
					end

					task.wait(1)
				end
			end
		else
			logMsg("[Trade] Skipping add-items (already met)", CL_DIM)
		end

		-- เช็คเงื่อนไข accept
		local effectiveSelfValue = FruitValueSelf + addedValue
		logMsg(("[Trade] effectiveSelf=%d (Self %d + added %d)"):format(
			effectiveSelfValue, FruitValueSelf, addedValue
		), CL_INFO)

		local canAccept = (not args.Ready[playerNumber]) and FruitValueOther > 0 and effectiveSelfValue > 0 and (FruitValueOther / effectiveSelfValue) * 100 >= 60
		logMsg("[Trade] Accept conditions:", CL_INFO)
		logMsg(("[Trade]   - not ready: %s"):format(tostring(not args.Ready[playerNumber])), CL_DIM)
		logMsg(("[Trade]   - Other>0: %s (=%d)"):format(tostring(FruitValueOther > 0), FruitValueOther), CL_DIM)
		logMsg(("[Trade]   - effSelf>0: %s (=%d)"):format(tostring(effectiveSelfValue > 0), effectiveSelfValue), CL_DIM)
		if effectiveSelfValue > 0 then
			local ratio = (FruitValueOther / effectiveSelfValue) * 100
			logMsg(("[Trade]   - ratio>=60%%: %s (=%.1f%%)"):format(tostring(ratio >= 60), ratio), CL_DIM)
		end

        if canAccept then
            logMsg("[Trade] >> Pressing ACCEPT", CL_OK)
            local ok, err = pcall(function()
                TradeFunction:InvokeServer("accept")
            end)
            if not ok then
                logMsg("[Trade] X accept failed: " .. tostring(err), CL_ERR)
            end
        else
            logMsg("[Trade] X Not accepting yet", CL_WARN)
        end

        logMsg("========== End ==========\n", CL_HEAD)
		TradeBusy = false
	end
end)
