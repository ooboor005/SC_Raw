function getIndices(dataTable, targetValue)
    local entries = {}
    
    for k, v in pairs(dataTable) do
        table.insert(entries, {index = k, value = v})
    end

    table.sort(entries, function(a, b) return a.value > b.value end)

    local threshold = targetValue * 0.6 
    local currentSum = 0
    local resultIndices = {} 

    for i = 1, math.min(4, #entries) do
        print("Checking:", entries[i].index, "with value:", entries[i].value)
        currentSum = currentSum + entries[i].value
        table.insert(resultIndices, entries[i].index)
        if currentSum > threshold then
            return resultIndices
        end
    end
    return {} 
end

-- ✅ FIX: lock ป้องกัน update_state event ยิงซ้อนกันขณะกำลังประมวลผล
local TradeBusy = false

TradeEvent.OnClientEvent:Connect(function(action, args)
	if action == "update_state" then
		if TradeBusy then
			return
		end
		TradeBusy = true

		local playerNumber = args["Player1"].Name == LocalPlayer.Name and 1 or args["Player2"].Name == LocalPlayer.Name and 2 or nil
		if not playerNumber then
			TradeBusy = false
			return
		end
		local FruitValueSelf = 0
		local FruitValueOther = 0
		for i,v in pairs(args.Offer[playerNumber]) do 
			FruitValueSelf += v.Price 
		end
		for i,v in pairs(args.Offer[playerNumber == 1 and 2 or 1]) do 
			FruitValueOther += v.Price 
		end

		local alreadyOffered = {}
		for i, v in pairs(args.Offer[playerNumber]) do
			alreadyOffered[v.Name] = true
		end

		-- ✅ FIX: เก็บมูลค่าที่เพิ่งใส่เพิ่มในรอบนี้ เพื่อใช้คำนวณ Self ใหม่หลัง addItem จบ
		local addedValue = 0

		if (FruitValueSelf == 0) or not (not args.Ready[playerNumber] and FruitValueOther > 0 and FruitValueSelf > 0 and (FruitValueOther / FruitValueSelf) * 100 >= 60 ) then 
            refreshFruitMapping()

            for name, _ in pairs(alreadyOffered) do
                FruitMapping[name] = nil
            end

            local fruitIndices = getIndices(FruitMapping, FruitValueOther)
            for i,v in pairs(fruitIndices) do 
                local val = FruitMapping[v] or 0
                TradeFunction:InvokeServer("addItem", v)
				print("Senting Fruit:", v, "value:", val)
				addedValue += val
				task.wait(1)
            end
        end

        -- ✅ FIX: ใช้ Self ใหม่ที่รวม addedValue แล้ว ไม่ต้องรอ event รอบถัดไป
        local effectiveSelfValue = FruitValueSelf + addedValue

        if not args.Ready[playerNumber] and FruitValueOther > 0 and effectiveSelfValue > 0 and (FruitValueOther / effectiveSelfValue) * 100 >= 60 then
            TradeFunction:InvokeServer("accept")
            print("Accept trade fired (Self:", effectiveSelfValue, "Other:", FruitValueOther, ")")
        end

		TradeBusy = false
	end
end)
