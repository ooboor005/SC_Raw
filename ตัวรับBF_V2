-- ✅ FIX: ทำเป็นฟังก์ชันแยก เพื่อ refresh inventory ใหม่ได้ทุกครั้ง
function refreshFruitMapping()
    table.clear(FruitMapping)
    local ok, Inv = pcall(function()
        return _CommF:InvokeServer("getInventory")
    end)
    if not ok or typeof(Inv) ~= "table" then
        warn("[Trade] refreshFruitMapping ล้มเหลว:", Inv)
        return
    end
    for i, v in pairs(Inv) do
        if v.Type == "Blox Fruit" then
            FruitMapping[v.Name] = v.Value
        end
    end
end

